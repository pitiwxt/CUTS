# =================================================================
# Zocial Tracker - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# =================================================================

# 🧠 Google Gemini API (For Playwright OCR Fallback)
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 💾 Supabase Database Connection
# Find these in Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# 📋 Google Sheets API Configurations
# The Sheet ID can be extracted from the Google Sheet URL
GOOGLE_SHEET_ID=your-google-sheet-id-here

# 🔐 Optional: Instagram Credentials (For Playwright Login Fallback)
# Leave blank to run Vision scraper as guest (limited to public views)
META_USERNAME=your_instagram_email_or_username
META_PASSWORD=your_instagram_password

# 🌐 Meta & TikTok API Access Tokens (For n8n Tier 1 Workflows)
META_ACCESS_TOKEN=your_facebook_instagram_long_lived_access_token
IG_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
TIKTOK_ACCESS_TOKEN=your_tiktok_business_access_token
