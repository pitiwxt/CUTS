# =============================
# Club OS — Environment Variables
# =============================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# --- Groq API (OCRchat vision) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# --- Supabase ---
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_KEY=sb_secret_your_key_here

# --- Google Sheets (Zocial Tracker data source) ---
# Spreadsheet ID from URL: docs.google.com/spreadsheets/d/{ID}/edit
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# --- Google Apps Script Webhook (expense → Sheets auto-sync) ---
# Deploy Apps Script as Web App (Anyone, no auth) and paste URL here
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# --- Apify (Tier 3 scraper) ---
# Get from: https://console.apify.com → Settings → Integrations
APIFY_TOKEN=apify_api_your_token_here

# --- Gemini (AI Assistant chat) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_key_here
